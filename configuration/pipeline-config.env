# ============================================================================
# pipline-config.env - Fill this in ONCE before running the Bootstrap pipeline
# ============================================================================
# This is the single source of truth for all project-specific values.
# Every pipeline and CloudFormation template reads from here.
# Do NOT put secrets (passwords, access keys) in this file.
# Secrets go into Bitbucket Repository Variables (see Readme.md)
# ============================================================================

#  ̶̶ ̶̶ BITBUCKET  ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶

# Your Bitbucket workspace slug.
# Found in your workspace URL: https://bitbucket.org/{WORKSPACE_SLUG}
WORKSPACE_SLUG=YOUR_WORKSPACE_SLUG

# Your Bitbucket workspace UUID (includes curly braces).
# Found at: Bitbucket → Your workspace → Settings → Workspace details
WORKSPACE_UUID={YOUR_WORKSPACE_UUID}

# Your Bitbucket repository slug.
# Found in your repo URL: https://bitbucket.org/{workspace}/{REPO_SLUG}/
REPO_SLUG=YOUR_REPO_SLUG


#  ̶̶ ̶̶ AWS  ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶

# AWS region where all infrastructure will be deployed.
# Example value: ap-south-1 | us-east-1 | eu-west-1
AWS_REGION=ap-south-1

# S3 bucket name for hosting Allure reports.
# IMPORTANT: Must be globally unique across all of AWS (not two accounts can share a name).
# Use lowercase letters, numbers and hyphens only. No spaces or underscores.
# Example: mycompany-myproject-allure-projects
S3_BUCKET_NAME=YOUR_PROJECT_NAME-allure-projects


#  ̶̶ ̶̶ NAMING  ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶ ̶̶

# Short prefix used to name CloudFormation stacks and the IAM role.
# Use lowercase letters, numbers and hyphens only. No spaces.
# Example: myproject
STACK_PREFIX=myproject